<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Form</title>
    <!-- <link rel="stylesheet" href="/css/style.css"> -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
     integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body{
            margin:0;
            padding:0;
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg,#667eea,#764ba2);
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
        }
        .project-form{
            /* background:white; */
            padding:40px;
            border-radius:12px;
            width:400px;
            box-shadow:0 10px 25px rgba(0,0,0,0.2) !important;
        }
        .project-form h1{
            text-align:center;
            margin-bottom:20px;
        }

        .project-form label{
            font-weight:600;
            margin-top:10px;
            display:block;
        }

        .project-form input,
        .project-form textarea{
            width:100%;
            padding:10px;
            margin-top:5px;
            margin-bottom:15px;
            border:1px solid #ccc;
            border-radius:6px;
            font-size:14px;
            outline:none;
            transition:0.3s;
        }

        .project-form input:focus,
        .project-form textarea:focus{
            border-color:#667eea;
            box-shadow:0 0 5px rgba(102,126,234,0.5);
        }

        .project-form button{
            width:100%;
            padding:12px;
            border:none;
            background:#667eea;
            color:white;
            font-size:16px;
            border-radius:6px;
            cursor:pointer;
            transition:0.3s;
        }

        .project-form button:hover{
            background:#5a67d8;
        }
    </style>
</head>
<body>
    <div class="project-form">
        <h1>Project Form</h1>
        <form action="/projects" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
            <div class="singleData">
                <label for="title" >Name</label>
                <input type="text" name="title" class="form-control" required>
                <div class="invalid-feedback">Please provide name</div>
            </div>
            <div class="singleData">
                <label for="image">Image</label>
                <input type="file" name="image" class="form-control" required>
                <div class="invalid-feedback">Please provide Image</div>
            </div>
            <div class="singleData">
                <label for="github">Github Link</label>
                <input type="url" name="github" class="form-control">
            </div>
            <div class="singleData">
                <label for="live">Live Link</label>
                <input type="text" name="live" class="form-control">     
            </div>
            <div class="singleData">
                <label for="description" >Description</label>
                <textarea name="description" id="" cols="30" rows="10" class="form-control" required></textarea>
                <div class="invalid-feedback">Please provide description</div>
            </div>
            <button>Add Project</button>
        </form>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
</script>
</body>
</html>